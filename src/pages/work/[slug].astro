---
import type { GetStaticPaths } from 'astro'
import CaseStudyComponent from '../../components/CaseStudy.astro'
import PageFooter from '../../components/PageFooter.astro'
import { caseStudies } from '../../data/case-studies'
import Base from '../../layouts/Base.astro'

export const getStaticPaths: GetStaticPaths = () => {
  return caseStudies.map((cs) => ({
    params: { slug: cs.slug },
    props: cs,
  }))
}

const study = Astro.props
---
<Base title={`${study.title} — janice quach`} description={study.problem}>
    <div class="case-page">
        <a class="back-btn" href="/create" aria-label="Back to create">← back</a>
        <CaseStudyComponent {...study} />
        <nav class="case-nav">
            {caseStudies
                .filter((cs) => cs.slug !== study.slug)
                .map((cs) => (
                    <a class="case-nav-link" href={`/work/${cs.slug}`}>
                        <span class="case-nav-label">{cs.label}</span>
                        <span class="case-nav-title">{cs.title}</span>
                    </a>
                ))}
        </nav>
        <PageFooter theme="create" />
    </div>
</Base>

<style>
    .case-page {
        background: #e8e4de;
        min-height: 100vh;
        padding-top: 6rem;
    }

    .case-nav {
        max-width: 760px;
        margin: 0 auto;
        padding: 2rem 2rem 4rem;
        display: flex;
        gap: 1.5rem;
    }

    .case-nav-link {
        flex: 1;
        text-decoration: none;
        padding: 1.5rem;
        border-radius: 12px;
        border: 1px solid rgba(58, 53, 48, 0.08);
        background: rgba(255, 255, 255, 0.3);
        transition: all 0.25s ease;
    }

    .case-nav-link:hover {
        background: rgba(255, 255, 255, 0.6);
        border-color: rgba(58, 53, 48, 0.15);
        transform: translateY(-2px);
    }

    .case-nav-label {
        display: block;
        font-size: 0.6rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: rgba(58, 53, 48, 0.3);
        margin-bottom: 0.5rem;
    }

    .case-nav-title {
        display: block;
        font-family: 'DM Serif Display', Georgia, serif;
        font-size: 1rem;
        line-height: 1.3;
        color: #3a3530;
    }

    @media (max-width: 768px) {
        .case-nav {
            flex-direction: column;
            padding: 2rem 1.5rem 3rem;
        }
    }
</style>

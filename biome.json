{
    "$schema": "https://biomejs.dev/schemas/2.0.0/schema.json",
    "organizeImports": { "enabled": true },
    "linter": {
        "enabled": true,
        "rules": { "recommended": true }
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 120
    },
    "files": {
        "include": ["src/**/*.ts", "src/**/*.js", "src/**/*.astro", "*.mjs"],
        "ignore": ["node_modules", "dist", ".astro"]
    }
}
